# Run npm install / npm ci with legacy peer-dep resolution.
#
# Why: we depend on `@vite-pwa/astro@0.5.x`, whose `peerDependencies.astro`
# only lists `^1 || ^2 || ^3 || ^4 || ^5` — Astro 6 isn't published yet by
# upstream as a peer. The plugin itself works fine against v6 (it uses the
# stable Astro integration API), so we accept the ERESOLVE warning that
# `npm install` already downgrades; `npm ci` (used in CI) otherwise treats
# it as fatal and refuses to install.
#
# Drop this flag once `@vite-pwa/astro` ships a release with `astro@^6` in
# its peer list.
legacy-peer-deps=true
