---
import { getCollection } from "astro:content";
import Container from "./Container.astro";
import SectionHeading from "./SectionHeading.astro";

const projects = (await getCollection("projects")).map((p) => p.data);

/* Map our enum accent to CSS-variable stages so all colours come from one
 * palette and dark-mode swaps for free. */
const stageMap: Record<string, string> = {
  violet: "agent",
  emerald: "sink",
  sky: "store",
  amber: "stream",
  rose: "agent",
};
---

<section id="projects" class="relative py-20 sm:py-28 scroll-mt-12">
  <Container wide>
    <SectionHeading
      stageId="projects"
      title="Four case files."
      description="The work I'd point a hiring manager at."
    />

    <div class="grid gap-6 lg:grid-cols-2" data-reveal>
      {
        projects.map((p, idx) => {
          const stageKey = stageMap[p.accentColor] ?? "agent";
          const fileId = `CASE-${String(idx + 1).padStart(3, "0")}`;
          return (
            <article
              class="relative border border-[var(--rule)] bg-[var(--bg-elevated)] flex flex-col hover:border-[var(--rule-strong)] transition-colors"
              style={`--case-accent: var(--stage-${stageKey});`}
            >
              {/* Corner brackets — manual so they can use --case-accent */}
              <span aria-hidden="true" class="absolute -top-px -left-px w-3 h-3 border-t border-l" style="border-color:var(--case-accent);" />
              <span aria-hidden="true" class="absolute -top-px -right-px w-3 h-3 border-t border-r" style="border-color:var(--case-accent);" />
              <span aria-hidden="true" class="absolute -bottom-px -left-px w-3 h-3 border-b border-l" style="border-color:var(--case-accent);" />
              <span aria-hidden="true" class="absolute -bottom-px -right-px w-3 h-3 border-b border-r" style="border-color:var(--case-accent);" />

              {/* Header strip */}
              <header class="flex items-start justify-between gap-3 px-6 py-3 border-b border-[var(--rule)]">
                <div>
                  <p class="font-mono text-[10px] uppercase tracking-[0.16em] text-[var(--fg-subtle)]">
                    {fileId} · {p.company} · {p.period}
                  </p>
                </div>
                <span
                  class="font-mono text-[10px] uppercase tracking-wider px-1.5 py-0.5 border"
                  style="border-color:var(--case-accent); color:var(--case-accent);"
                >
                  case file
                </span>
              </header>

              <div class="px-6 py-6 flex-1 flex flex-col">
                <h3 class="font-display text-2xl sm:text-[1.75rem] leading-tight text-[var(--fg)]">
                  {p.title}
                </h3>
                <p class="mt-1.5 text-sm" style="color:var(--case-accent)">
                  {p.subtitle}
                </p>

                <p class="mt-5 text-[14.5px] text-[var(--fg-muted)] leading-relaxed">
                  {p.summary}
                </p>

                {/* Metrics */}
                <dl class="mt-6 grid grid-cols-2 gap-[1px] bg-[var(--rule)] border border-[var(--rule)]">
                  {p.metrics.map((m) => (
                    <div class="bg-[var(--bg)] p-3.5">
                      <dt class="font-mono text-[9.5px] uppercase tracking-[0.12em] text-[var(--fg-subtle)]">
                        {m.label}
                      </dt>
                      <dd class="mt-1 font-display text-lg text-[var(--fg)]">
                        {m.value}
                      </dd>
                    </div>
                  ))}
                </dl>

                {/* Stack */}
                <ul class="mt-6 flex flex-wrap gap-1.5">
                  {p.stack.map((s) => (
                    <li class="tag">{s}</li>
                  ))}
                </ul>
              </div>
            </article>
          );
        })
      }
    </div>
  </Container>
</section>
