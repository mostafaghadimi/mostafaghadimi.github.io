---
import Container from "./Container.astro";
import SectionHeading from "./SectionHeading.astro";
import { site } from "~/data/site";

const channels = [
  {
    cmd: "$ mail mostafa",
    label: "Email",
    value: site.author.email,
    href: `mailto:${site.author.email}`,
    primary: true,
  },
  {
    cmd: "$ open linkedin",
    label: "LinkedIn",
    value: `in/${site.author.linkedin}`,
    href: `https://www.linkedin.com/in/${site.author.linkedin}/`,
  },
  {
    cmd: "$ open telegram",
    label: "Telegram",
    value: `t.me/${site.author.telegram}`,
    href: `https://t.me/${site.author.telegram}`,
  },
  {
    cmd: "$ gh user",
    label: "GitHub",
    value: `@${site.author.github}`,
    href: `https://github.com/${site.author.github}`,
  },
];
---

<section id="contact" class="relative py-20 sm:py-28 scroll-mt-12">
  <Container wide>
    <SectionHeading
      stageId="contact"
      title="Get in touch."
      description="Email is fastest. I read every message."
    />

    <div
      class="relative border border-[var(--rule)] bg-[var(--bg-elevated)] overflow-hidden"
      data-reveal
    >
      <!-- Terminal title bar -->
      <div class="flex items-center justify-between gap-3 px-4 py-2 border-b border-[var(--rule)] bg-[var(--bg-soft)]">
        <div class="flex items-center gap-2">
          <span class="h-2.5 w-2.5 rounded-full bg-[#e84a4f]" aria-hidden="true"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#e8b341]" aria-hidden="true"></span>
          <span class="h-2.5 w-2.5 rounded-full bg-[#56c563]" aria-hidden="true"></span>
        </div>
        <span class="font-mono text-[11px] text-[var(--fg-subtle)] truncate">
          mostafa@portfolio:~/contact &nbsp;—&nbsp; zsh
        </span>
        <span class="font-mono text-[11px] text-[var(--fg-subtle)] tabular-nums">
          {channels.length} channel{channels.length === 1 ? "" : "s"}
        </span>
      </div>

      <!-- Body -->
      <div class="px-5 sm:px-8 py-6 sm:py-8 font-mono text-sm">
        <p class="text-[var(--fg-muted)]">
          <span class="text-[var(--fg-subtle)]">$</span>{" "}
          <span class="text-[var(--fg)]">list --channels</span>
        </p>

        <ul class="mt-3 divide-y divide-[var(--rule)] border-y border-[var(--rule)]">
          {
            channels.map((c) => (
              <li>
                <a
                  href={c.href}
                  target={c.href.startsWith("http") ? "_blank" : undefined}
                  rel={c.href.startsWith("http") ? "noreferrer noopener" : undefined}
                  class={`group flex items-center justify-between gap-4 px-2 sm:px-3 py-3.5 hover:bg-[var(--bg-soft)] transition-colors ${c.primary ? "bg-[color-mix(in_srgb,var(--accent)_6%,transparent)]" : ""}`}
                >
                  <span class="flex items-center gap-3 min-w-0">
                    <span class={`text-[11px] tabular-nums ${c.primary ? "text-[var(--accent)]" : "text-[var(--fg-subtle)]"}`}>
                      {c.cmd}
                    </span>
                    <span class="text-[var(--fg-subtle)] hidden sm:inline">→</span>
                    <span class="text-[var(--fg)] group-hover:text-[var(--accent)] truncate">
                      {c.value}
                    </span>
                  </span>
                  <span class="font-sans text-[11px] uppercase tracking-wider text-[var(--fg-subtle)] shrink-0">
                    {c.label}
                  </span>
                </a>
              </li>
            ))
          }
        </ul>

        <p class="mt-5 text-[var(--fg-muted)]">
          <span class="text-[var(--fg-subtle)]">$</span>{" "}
          <span class="text-[var(--fg)]">echo $RESPONSE_TIME</span>
          <span class="ml-2 text-[var(--fg-muted)]">→ usually within 24h</span>
          <span class="inline-block ml-1 align-middle h-3.5 w-2 bg-[var(--accent)] animate-pulse"></span>
        </p>
      </div>
    </div>

    <div class="mt-6 flex flex-wrap items-center gap-3" data-reveal>
      <a
        href={`mailto:${site.author.email}`}
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-[var(--bg)] bg-[var(--fg)] hover:bg-[var(--accent)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
          <polyline points="22,6 12,13 2,6"/>
        </svg>
        Send me an email
      </a>
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener"
        download
        class="inline-flex items-center gap-2 px-5 py-2.5 text-sm font-medium text-[var(--fg)] border border-[var(--rule-strong)] hover:border-[var(--accent)] hover:text-[var(--accent)] transition-colors"
      >
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/>
          <polyline points="7 10 12 15 17 10"/>
          <line x1="12" y1="15" x2="12" y2="3"/>
        </svg>
        resume.pdf
      </a>
    </div>
  </Container>
</section>
