---
type Props = {
  as?: string;
  class?: string;
  id?: string;
  wide?: boolean;
};
const { as: Tag = "div", class: className = "", id, wide = false } = Astro.props;
const max = wide ? "max-w-7xl" : "max-w-5xl";
---

<Tag id={id} class={`mx-auto w-full ${max} px-5 sm:px-8 lg:px-12 ${className}`}>
  <slot />
</Tag>
