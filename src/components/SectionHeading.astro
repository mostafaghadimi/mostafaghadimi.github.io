---
import { stages, type StageId } from "~/data/stages";

interface Props {
  stageId: StageId;
  title: string;
  description?: string;
}
const { stageId, title, description } = Astro.props;
const stage = stages.find((s) => s.id === stageId);
if (!stage) {
  throw new Error(`No stage found for id "${stageId}"`);
}

// A reproducible "timestamp" derived from the stage index so it looks like
// a log line but doesn't churn between server renders.
const ts = `15:42:${stage.index}.001Z`;
---

<header class="mb-10 sm:mb-12" data-reveal>
  <!-- Terminal log eyebrow -->
  <p class="log-line">
    <span class="stage">[STAGE {stage.index}]</span>
    <span class="ts">{ts}</span>
    <span class="prompt">user@portfolio:~$</span>
    <span class="cmd">{stage.cmd.replace(/^\$\s*/, "")}</span>
  </p>

  <h2
    class="mt-4 font-display text-[2.25rem] sm:text-[3rem] lg:text-[3.5rem] leading-[1.04] tracking-[-0.02em] text-[var(--fg)]"
  >
    <slot name="title">{title}</slot>
  </h2>

  {
    description && (
      <p class="mt-3 max-w-2xl text-base sm:text-lg text-[var(--fg-muted)] leading-relaxed">
        {description}
      </p>
    )
  }

  <!-- Decorative tape divider -->
  <div class="tape mt-7 max-w-[16rem]" aria-hidden="true"></div>
</header>
