---
/**
 * Pipeline diagram, v3 — two parallel curved tracks, animated, visually rich.
 *
 *   DATA  ⤳  events  ⤳  Kafka  ⤳  ClickHouse  ⤳  BI / Reports
 *   AGENT ⤳  inbound ⤳  LangChain ⤳  tools   ⤳  reply
 *
 * Each track is a smooth bezier wave through 4 stations. Stations are
 * layered circles (glow halo + breathing pulse + filled core + icon). Edges
 * carry per-segment gradient strokes that blend stage colours. Multiple
 * accent-coloured event dots ride each track along a real `offset-path: path(...)`
 * with staggered animation delays so the pipelines feel "live".
 *
 * The two tracks are bridged in the middle by a small "same hands" connector,
 * keeping the visual story coherent without forcing the two flows to merge.
 *
 * Sized for plenty of room — viewBox 0 0 1000 360 — so nothing ever clips.
 */

type Station = {
  label: string;
  sub: string;
  stage: "source" | "stream" | "store" | "serve" | "agent" | "sink";
  icon: "db" | "stream" | "warehouse" | "chart" | "inbox" | "brain" | "tools" | "send";
};

type Track = {
  id: "data" | "agent";
  rowLabel: string;
  caption: string;
  centerY: number;
  // Per-station y offset (±) to form a gentle wave
  yWave: number[];
  stations: Station[];
};

const tracks: Track[] = [
  {
    id: "data",
    rowLabel: "DATA",
    caption: "stream → store → serve",
    centerY: 105,
    yWave: [0, -22, 0, -22],
    stations: [
      { label: "events",     sub: "postgres · cdc",       stage: "source", icon: "db" },
      { label: "Kafka",      sub: "debezium · KRaft",     stage: "stream", icon: "stream" },
      { label: "ClickHouse", sub: "warehouse · dbt",      stage: "store",  icon: "warehouse" },
      { label: "Analytics",  sub: "metabase · datahub",   stage: "sink",   icon: "chart" },
    ],
  },
  {
    id: "agent",
    rowLabel: "AGENT",
    caption: "listen → reason → reply",
    centerY: 255,
    yWave: [0, 22, 0, 22],
    stations: [
      { label: "inbound",   sub: "tenant message",       stage: "agent",  icon: "inbox" },
      { label: "LangChain", sub: "graph · memory",       stage: "agent",  icon: "brain" },
      { label: "tools",     sub: "rag · @tool calls",    stage: "serve",  icon: "tools" },
      { label: "reply",     sub: "delivered",            stage: "sink",   icon: "send" },
    ],
  },
];

const VB_W = 1000;
const VB_H = 360;
// Station x positions are kept symmetric around the centre (midpoint of
// stations 1+2 = 500, where the "you" bridge sits). Compared to the previous
// [140, 380, 620, 860] layout, station 0 was pushed right to 200 so the row
// caption ("stream → store → serve" / "listen → reason → reply") on the
// far-left has a clean gap before the first station's halo and the last
// word doesn't get eaten by the green/magenta glow.
const STATION_XS = [200, 400, 600, 800];

// Build a smooth path through 4 stations using cubic beziers between each pair
function trackPath(centerY: number, yWave: number[]): string {
  const points = STATION_XS.map((x, i) => ({ x, y: centerY + yWave[i] }));
  let d = `M ${points[0].x} ${points[0].y}`;
  for (let i = 0; i < points.length - 1; i++) {
    const a = points[i];
    const b = points[i + 1];
    const mx = (a.x + b.x) / 2;
    d += ` C ${mx} ${a.y}, ${mx} ${b.y}, ${b.x} ${b.y}`;
  }
  return d;
}
---

<figure
  class="pipeline relative w-full"
  role="img"
  aria-label="Two parallel animated pipelines — data: events → Kafka → ClickHouse → Analytics; agent: inbound → LangChain → tools → reply"
>
  <svg
    viewBox={`0 0 ${VB_W} ${VB_H}`}
    preserveAspectRatio="xMidYMid meet"
    class="w-full h-auto block"
    fill="none"
    xmlns="http://www.w3.org/2000/svg"
  >
    <defs>
      {/* Per-segment gradient strokes, blending consecutive station colours */}
      {tracks.flatMap((t) =>
        t.stations.slice(0, -1).map((s, i) => (
          <linearGradient
            id={`grad-${t.id}-${i}`}
            x1={STATION_XS[i]}
            y1="0"
            x2={STATION_XS[i + 1]}
            y2="0"
            gradientUnits="userSpaceOnUse"
          >
            <stop offset="0%" stop-color={`var(--stage-${s.stage})`} stop-opacity="0.85" />
            <stop offset="100%" stop-color={`var(--stage-${t.stations[i + 1].stage})`} stop-opacity="0.85" />
          </linearGradient>
        )),
      )}

      {/* Soft glow filter for station halos */}
      <filter id="halo" x="-50%" y="-50%" width="200%" height="200%">
        <feGaussianBlur stdDeviation="3" result="blur" />
        <feMerge>
          <feMergeNode in="blur" />
          <feMergeNode in="SourceGraphic" />
        </feMerge>
      </filter>
    </defs>

    {/* Render each track */}
    {
      tracks.map((track) => {
        const pathD = trackPath(track.centerY, track.yWave);
        const segments = track.stations.slice(0, -1).map((_, i) => {
          const a = { x: STATION_XS[i],     y: track.centerY + track.yWave[i] };
          const b = { x: STATION_XS[i + 1], y: track.centerY + track.yWave[i + 1] };
          const mx = (a.x + b.x) / 2;
          return `M ${a.x} ${a.y} C ${mx} ${a.y}, ${mx} ${b.y}, ${b.x} ${b.y}`;
        });

        return (
          <g class="track" data-track={track.id}>
            {/* Row label on the far left */}
            <g class="track-label" transform={`translate(40, ${track.centerY})`}>
              <text
                x="0"
                y="-2"
                font-family="var(--font-mono)"
                font-size="11"
                font-weight="600"
                letter-spacing="3"
                fill="var(--fg)"
              >
                {track.rowLabel}
              </text>
              <text
                x="0"
                y="14"
                font-family="var(--font-mono)"
                font-size="9.5"
                fill="var(--fg-subtle)"
              >
                {track.caption}
              </text>
            </g>

            {/* Per-segment curved strokes with gradient colour */}
            {segments.map((d, i) => (
              <path
                d={d}
                stroke={`url(#grad-${track.id}-${i})`}
                stroke-width="2"
                fill="none"
                stroke-linecap="round"
              />
            ))}

            {/* Stations */}
            {track.stations.map((s, i) => {
              const cx = STATION_XS[i];
              const cy = track.centerY + track.yWave[i];
              return (
                <g class="station" transform={`translate(${cx},${cy})`}>
                  {/* Outermost halo (very low opacity, big) — gives a soft glow */}
                  <circle
                    r="22"
                    fill={`var(--stage-${s.stage})`}
                    opacity="0.10"
                    class="station-halo"
                  />
                  {/* Breathing ring */}
                  <circle
                    r="14"
                    fill="none"
                    stroke={`var(--stage-${s.stage})`}
                    stroke-width="1.2"
                    opacity="0.55"
                    class="station-ring"
                  />
                  {/* Solid core (paper-bg) so the line behind doesn't show */}
                  <circle
                    r="11"
                    fill="var(--bg-elevated)"
                    stroke={`var(--stage-${s.stage})`}
                    stroke-width="2.25"
                  />
                  {/* Icon set — small, monochrome stage-coloured */}
                  <g
                    stroke={`var(--stage-${s.stage})`}
                    stroke-width="1.4"
                    fill="none"
                    stroke-linecap="round"
                    stroke-linejoin="round"
                    transform="translate(-5,-5)"
                  >
                    {s.icon === "db" && (
                      <g>
                        <ellipse cx="5" cy="2" rx="5" ry="1.5" />
                        <path d="M0 2v5c0 .9 2.2 1.6 5 1.6S10 7.9 10 7V2" />
                        <path d="M0 6v4c0 .9 2.2 1.6 5 1.6S10 10.9 10 10V6" />
                      </g>
                    )}
                    {s.icon === "stream" && (
                      <g>
                        <path d="M0 2h10M0 6h7M0 10h10" />
                      </g>
                    )}
                    {s.icon === "warehouse" && (
                      <g>
                        <rect x="0" y="1" width="10" height="9" />
                        <path d="M0 4h10M0 7h10M3.3 1v9M6.6 1v9" />
                      </g>
                    )}
                    {s.icon === "chart" && (
                      <g>
                        <path d="M0 10h10M1 8V5M4 8V2M7 8V6" />
                      </g>
                    )}
                    {s.icon === "inbox" && (
                      <g>
                        <path d="M0 6v3a1 1 0 0 0 1 1h8a1 1 0 0 0 1-1V6" />
                        <path d="M0 6l1.5-4h7L10 6" />
                        <path d="M0 6h3l1 1.5h2L7 6h3" />
                      </g>
                    )}
                    {s.icon === "brain" && (
                      <g>
                        <circle cx="3.2" cy="5" r="2.5" />
                        <circle cx="6.8" cy="5" r="2.5" />
                        <path d="M3.2 2.5V0.6M6.8 2.5V0.6M3.2 7.5v1.9M6.8 7.5v1.9M5 5h0.1" />
                      </g>
                    )}
                    {s.icon === "tools" && (
                      <g>
                        <path d="M1 9l4-4M3 7l-3 3M6 4l3-3M4 6l5 3" />
                        <circle cx="2" cy="2" r="1.3" />
                        <circle cx="8" cy="8" r="1.3" />
                      </g>
                    )}
                    {s.icon === "send" && (
                      <g>
                        <path d="M10 0L0 5l4 1.5L5 10l5-10z" />
                      </g>
                    )}
                  </g>

                  {/* Label below the station */}
                  <text
                    x="0"
                    y="32"
                    text-anchor="middle"
                    font-family="var(--font-sans)"
                    font-size="13.5"
                    font-weight="600"
                    fill="var(--fg)"
                  >
                    {s.label}
                  </text>
                  <text
                    x="0"
                    y="46"
                    text-anchor="middle"
                    font-family="var(--font-mono)"
                    font-size="9.5"
                    fill="var(--fg-subtle)"
                  >
                    {s.sub}
                  </text>
                </g>
              );
            })}

            {/* Five flowing event dots ride the whole track path */}
            {[0, 0.8, 1.6, 2.4, 3.2].map((delay) => (
              <circle
                class="flow-dot"
                r="3.5"
                fill="var(--accent)"
                filter="url(#halo)"
                style={`offset-path: path('${pathD}'); animation: flow 4.2s linear infinite; animation-delay: ${delay}s;`}
              />
            ))}
          </g>
        );
      })
    }

    {/* "Same hands" connector — vertical dashed hairline between the tracks */}
    <g class="bridge">
      <line
        x1={VB_W / 2}
        y1={tracks[0].centerY + 55}
        x2={VB_W / 2}
        y2={tracks[1].centerY - 55}
        stroke="var(--rule-strong)"
        stroke-width="1"
        stroke-dasharray="3 4"
        opacity="0.6"
      />
      <circle cx={VB_W / 2} cy={(tracks[0].centerY + tracks[1].centerY) / 2} r="14" fill="var(--bg-elevated)" stroke="var(--rule-strong)" />
      <text
        x={VB_W / 2}
        y={(tracks[0].centerY + tracks[1].centerY) / 2 + 4}
        text-anchor="middle"
        font-family="var(--font-mono)"
        font-size="10"
        font-weight="600"
        letter-spacing="0.5"
        fill="var(--fg-muted)"
      >
        you
      </text>
    </g>
  </svg>

  <style>
    .pipeline .flow-dot {
      offset-rotate: 0deg;
      will-change: offset-distance, opacity;
      opacity: 0;
    }
    .pipeline .station-halo {
      animation: halo-pulse 3.4s ease-in-out infinite;
      transform-origin: center;
      transform-box: fill-box;
    }
    .pipeline .station-ring {
      animation: ring-breathe 2.8s ease-in-out infinite;
      transform-origin: center;
      transform-box: fill-box;
    }
    @keyframes halo-pulse {
      0%, 100% { opacity: 0.08; transform: scale(0.9); }
      50%      { opacity: 0.20; transform: scale(1.1); }
    }
    @keyframes ring-breathe {
      0%, 100% { opacity: 0.45; }
      50%      { opacity: 0.85; }
    }
    /* Stagger station pulses so the diagram doesn't pulse in lockstep */
    .pipeline .track .station:nth-child(odd) .station-halo,
    .pipeline .track .station:nth-child(odd) .station-ring {
      animation-delay: 0.9s;
    }
    .pipeline .track[data-track="agent"] .station-halo,
    .pipeline .track[data-track="agent"] .station-ring {
      animation-delay: 1.4s;
    }
  </style>
</figure>
